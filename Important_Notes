Azure KQL Queries
Query to find error in logs
let startTimestamp = ago(1d);
KubePodInventory
| where TimeGenerated > startTimestamp
| project ContainerID, PodName=Name, PodLabel, PodLabelJson=parsejson(PodLabel)
| where PodLabelJson[0]["app"] == "<pod_name>"
| distinct ContainerID, PodName, PodLabel
| join
(
ContainerLog
| where TimeGenerated > startTimestamp
)
on ContainerID
| project TimeGenerated, PodName, LogEntry
| order by TimeGenerated desc


