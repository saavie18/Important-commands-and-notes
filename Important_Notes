Query for getting ingestion volume in container log table at service level 
let startdatetime = "2023-07-21";
let enddatetime = "2023-07-22";
let query1 = 
ContainerLog
| where TimeGenerated  between (todatetime(startdatetime) .. todatetime(enddatetime))
| extend Timing = format_datetime(TimeGenerated,"MM-yyyy") 
| summarize sum(_BilledSize) by ContainerID,Computer,Timing
| project TotalVolume=format_bytes(sum__BilledSize,0,"GB"),ContainerID,Computer,Timing
| where TotalVolume != "0 GB"
| project TotalIngestionVolume=toint(replace_string(TotalVolume," GB","")),ContainerID,Computer,Timing;
let query2=KubePodInventory
| where TimeGenerated  between (todatetime(startdatetime) .. todatetime(enddatetime))
| extend Timing = format_datetime(TimeGenerated,"MM-yyyy") 
| distinct ContainerID,Name,ClusterName,ServiceName;
query1
| join kind=inner
(query2) on ContainerID
| project Timing,ContainerID,TotalIngestionVolume,Name,Computer,ClusterName,ServiceName
| summarize sum(TotalIngestionVolume) by ServiceName,ClusterName,Timing
| where isnotempty(ServiceName)

