Basic Logs Cost savings Query
Usage
| where IsBillable == true
| where DataType has_any ("AppTraces","StorageFileLogs","ContainerLog","_CL")
| summarize MonthlyIngestionVolumeinGB = toint(sum(Quantity) / 1024) by DataType,ResourceUri
| project LogAnalyticsWorkspaceName=ResourceUri,DataType,MonthlyIngestionVolumeinGB
| extend Current_Costing=todouble(case(LogAnalyticsWorkspaceName has "die1-rc", 2.07 , 1.25))
| project LogAnalyticsWorkspaceName,DataType,MonthlyIngestionVolumeinGB,PerGBCostinUSD=todouble(Current_Costing)
| extend CurrentMonthlyCostinUSD=round(todouble(MonthlyIngestionVolumeinGB*PerGBCostinUSD),2)
| extend MonthlyCostinUSD_in_BasicLogs=round(todouble(MonthlyIngestionVolumeinGB*0.5),2)
| extend CostSavingsinUSD=todouble(CurrentMonthlyCostinUSD - MonthlyCostinUSD_in_BasicLogs)
| order by LogAnalyticsWorkspaceName desc


